# Optional overrides for `docker compose up`. Copy to `.env` and adjust if you
# want anything other than the local-dev defaults baked into docker-compose.yml.
# None of these are required to get the stack running.

DB_PASSWORD=moola
MYSQL_ROOT_PASSWORD=moola_root

# must be at least 32 characters (256 bits) for HS256 signing to work
JWT_SECRET=local-dev-secret-change-me-please-32chars-min
JWT_EXPIRATION=900000

# Leave empty to run without AI advice (it degrades to a placeholder message)
GROQ_KEY=
GROQ_URL=https://api.groq.com/openai/v1/chat/completions

FRANKFURTER_URL=https://api.frankfurter.dev/v2
